import java.util.Arrays;

class Main {
    public static void main(String[] args) {
        int[] a = {1, 2, 3, 4, 5, 6, 7};
        int k = 3;
        int n = a.length;
        k = k % n;
        for (int i = 0; i < k; i++) {
            int lastElement = a[n - 1];
            for (int j = n - 1; j > 0; j--) {
                a[j] = a[j - 1];
            }
            a[0] = lastElement;
        }
        System.out.println(Arrays.toString(a));
    }
}
